# ====================
# CRM_CRT BACKEND ENV
# ====================
# ⚠️  NUNCA commitear .env con valores reales — este archivo es solo de referencia
# Generar JWT secrets con: node -e "require('crypto').randomBytes(64).toString('hex')"

# Database
DATABASE_URL="postgresql://postgres:PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?schema=crm_crt"

# JWT — mínimo 64 caracteres hex, generados con crypto.randomBytes(64)
JWT_SECRET="GENERATE_WITH_CRYPTO_RANDOMBYTES_64_HEX"
JWT_EXPIRATION="15m"
JWT_REFRESH_SECRET="GENERATE_WITH_CRYPTO_RANDOMBYTES_64_HEX_DIFFERENT_FROM_ABOVE"
JWT_REFRESH_EXPIRATION="7d"

# App
PORT=3000
NODE_ENV=production
FRONTEND_URL="https://tu-frontend.vercel.app"
FRONTEND_URL_ALT="https://tu-frontend-preview.vercel.app"

# Rate Limiting
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# Swagger (deshabilitado en producción por defecto — activar solo en staging)
# SWAGGER_ENABLED=true

# Supabase (opcional - para storage)
SUPABASE_URL="https://PROJECT_REF.supabase.co"
SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_KEY="your-service-role-key"
